NODE_ENV=development
SERVICE_NAME=auth-service
PORT=4001
LOG_LEVEL=info

MONGO_URI=mongodb://mongo:27017/auth_db
REDIS_URL=redis://redis:6379

# JWT — minimum 32 chars enforced by Joi at boot.
JWT_ACCESS_SECRET=dev-only-secret-please-change-min-32-chars-aaaa
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# bcrypt cost factor. 12 ≈ 250ms on modern hardware — fine for login frequency, costly for brute-forcers.
BCRYPT_COST=12

# CORS (gateway is what the browser hits, but if anyone hits us direct we still want safety).
CORS_ALLOWLIST=http://localhost:3000,http://localhost:8080
