# API Gateway env. Loaded directly by docker-compose via env_file.
# For local non-docker dev, copy this to .env and edit.

NODE_ENV=development
SERVICE_NAME=api-gateway
PORT=8080
LOG_LEVEL=info

# Redis (rate-limit store)
REDIS_URL=redis://redis:6379

# Downstream service URLs (Docker DNS names)
AUTH_SERVICE_URL=http://auth-service:4001
PRODUCT_SERVICE_URL=http://product-service:4002
ORDER_SERVICE_URL=http://order-service:4003
NOTIFICATION_SERVICE_URL=http://notification-service:4004

# JWT (only needed for decoding sub claim for user-keyed rate limits — verification stays at services)
JWT_ACCESS_SECRET=dev-only-secret-please-change-min-32-chars-aaaa

# CORS allowlist (comma-separated). Example for a local SPA.
CORS_ALLOWLIST=http://localhost:3000

# Rate limits (requests per minute)
RATE_LIMIT_IP_PER_MIN=100
RATE_LIMIT_USER_PER_MIN=1000

# Timeouts (ms)
UPSTREAM_TIMEOUT_MS=3000
