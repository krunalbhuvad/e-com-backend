NODE_ENV=development
SERVICE_NAME=order-service
PORT=4003
LOG_LEVEL=info

# Order owns ONLY order_db. Note: there is NO MONGO_URI for product_db here. That's the point
# of DB-per-service — order has no way to query product state except via the product API.
MONGO_URI=mongodb://mongo:27017/order_db

REDIS_URL=redis://redis:6379
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672

JWT_ACCESS_SECRET=dev-only-secret-please-change-min-32-chars-aaaa

PRODUCT_SERVICE_URL=http://product-service:4002
PRODUCT_SERVICE_TIMEOUT_MS=3000

# Idempotency key TTL (seconds). Spec says 24h.
IDEMPOTENCY_TTL_SECONDS=86400

CORS_ALLOWLIST=http://localhost:3000,http://localhost:8080
