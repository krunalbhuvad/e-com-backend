NODE_ENV=development
SERVICE_NAME=product-service
PORT=4002
LOG_LEVEL=info

MONGO_URI=mongodb://mongo:27017/product_db
REDIS_URL=redis://redis:6379
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672

# Shared JWT secret — product-service verifies tokens minted by auth-service.
JWT_ACCESS_SECRET=dev-only-secret-please-change-min-32-chars-aaaa

# Cache TTL (seconds) for product reads
PRODUCT_CACHE_TTL_SECONDS=300

CORS_ALLOWLIST=http://localhost:3000,http://localhost:8080
